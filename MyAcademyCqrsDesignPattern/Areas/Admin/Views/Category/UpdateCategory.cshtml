@model UpdateCategoryCommand


@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<form method="post">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Kategori Adı</label>
        <input asp-for="Name" class="form-control" type="text" placeholder="Kategori adını giriniz..."  />
    </div>
    <br />

    <span class="text-danger">@Html.ValidationSummary()</span>

    <button class="btn btn-outline-success">Düzenle</button>

</form>

