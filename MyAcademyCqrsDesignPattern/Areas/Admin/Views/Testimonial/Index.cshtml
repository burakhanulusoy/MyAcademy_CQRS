@model List<GetTestimonialsQueryResult>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int count = 0;
}


<table class="table table-hover table-bordered">

    <tr>
        <th>#</th>
        <th>Yorum Sahibi</th>
        <th>Yorum</th>
        <th>Meslek</th>
        <th>İşlemeler</th>
    </tr>


    @foreach (var item in Model)
    {
        count++;
        <tr>
            <th>
                @count
                <img src="@item.ImageUrl" style="height:250px;width:250px" />
            </th>
            <td>@item.FullName</td>
            <td>@item.Comment</td>
            <td>@item.Title</td>
            <td>
                <a href="/Admin/Testimonial/UpdateTestimonial/@item.Id" class="btn btn-info">Düzenle</a>
                <button onclick="deleteTestimonial(@item.Id)" class="btn btn-danger">Sil</button>

            </td>
        </tr>



    }



</table>

<a href="/Admin/Testimonial/CreateTestimonial" class="btn btn-success">Yeni Yorum Oluştur</a>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function deleteTestimonial(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Evet, sil!",
            cancelButtonText: "İptal"
        }).then((result) => {
            if (result.isConfirmed) {

                // Başarı mesajını ayarla ve bitmesini bekle
                Swal.fire({
                    title: "Silindi!",
                    text: "Öğeniz başarılı bir şekilde silindi.",
                    icon: "success",
                    showConfirmButton: false, // Onay butonunu gizle
                    timer: 2000, // Ekranda 2 saniye (2000ms) kalsın
                    timerProgressBar: true // Şık bir geri sayım barı ekle
                }).then(() => {
                    // Alert süresi dolup kapandıktan SONRA yönlendirmeyi yap
                    window.location.href = "/Admin/Testimonial/DeleteTestimonial/" + id;
                });

            }
        });
    }
</script>


